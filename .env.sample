# fm-odata-js - local dev / live-integration configuration
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# These variables are consumed by the opt-in live integration tests that hit a
# real FileMaker Server (landing in M3+). Unit tests do NOT need any of this.
#
# Env var names are aligned with the FM-ODATA_SPEC standard:
#   FM_SERVER, FM_DATABASE, FM_USER, FM_PASSWORD, FM_VERIFY_SSL, FM_TIMEOUT
#
# Legacy FM_ODATA_* names are still accepted as fallbacks. Standardized names
# take precedence when both are set.

# --- FileMaker Server -------------------------------------------------------

# Base URL of the FileMaker Server (no trailing slash). HTTPS is required by
# FMS; self-signed certs on LAN IPs are common in dev.
FM_SERVER=https://fms.example.com
# Legacy alias (still accepted): FM_ODATA_HOST=https://fms.example.com

# Solution / database name (case-sensitive, as it appears in FMS).
FM_DATABASE=Contacts
# Legacy alias (still accepted): FM_ODATA_DATABASE=Contacts

# Basic-auth credentials for an FMS account with fmrest / OData privileges.
# The library itself consumes a bearer token, but the test harness logs in via
# the FM Data API to mint one using these credentials.
FM_USER=admin
FM_PASSWORD=change-me
# Legacy aliases (still accepted): FM_ODATA_USER, FM_ODATA_PASSWORD

# --- Test harness -----------------------------------------------------------

# Set to 1 to enable the live-FMS integration suite. Default 0 keeps CI fast
# and offline (the in-process mock server is used instead).
FM_LIVE=0
# Legacy alias (still accepted): FM_ODATA_LIVE=0

# Set to 0 to disable TLS certificate verification for the live suite only
# (useful against LAN FMS boxes with self-signed certs). Never set to 0 in prod.
# Default is 1 (verify). Legacy alias FM_ODATA_INSECURE_TLS=1 has inverted logic.
FM_VERIFY_SSL=1

# Per-request timeout in milliseconds. Optional. Legacy: not previously set.
# FM_TIMEOUT=30000

# --- Expected schema (for assertions in live tests) -------------------------
#
# The `Contacts` test database is expected to expose these layouts/tables with
# the following relationships:
#   contact (id)
#     |-- address (contact_id)
#     |-- email   (contact_id)
#     |-- phone   (contact_id)
FM_ODATA_TABLE_CONTACT=contact
FM_ODATA_TABLE_ADDRESS=address
FM_ODATA_TABLE_EMAIL=email
FM_ODATA_TABLE_PHONE=phone
# --- Container test (M4 Part 2) --------------------------------------------

# Name of a container field on the `contact` table that the live integration
# suite can upload/download a tiny PNG to. Defaults to `photo`. Set to a
# different name if your solution uses one. The test soft-skips if the field
# does not exist.
FM_ODATA_CONTAINER_FIELD=photo_content
