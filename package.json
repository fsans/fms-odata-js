{
  "name": "fm-odata-js",
  "version": "0.1.6",
  "description": "Zero-runtime-dependency TypeScript client for FileMaker Server OData v4 (Web Viewer, browser, Node).",
  "type": "module",
  "main": "./dist/fm-odata.esm.js",
  "module": "./dist/fm-odata.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fm-odata.esm.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:types && npm run build:esm && npm run build:min",
    "build:types": "tsc -p tsconfig.build.json",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --target=es2020 --outfile=dist/fm-odata.esm.js",
    "build:min": "esbuild src/index.ts --bundle --format=esm --target=es2020 --minify --outfile=dist/fm-odata.esm.min.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write .",
    "size": "gzip -c dist/fm-odata.esm.min.js | wc -c",
    "probe": "node scripts/probe.mjs"
  },
  "keywords": [
    "filemaker",
    "fms",
    "odata",
    "rest",
    "web-viewer",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
